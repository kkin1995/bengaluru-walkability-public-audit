# P0-1: Replace CHANGEME_STRONG_PASSWORD with a real secret before running.
# Never commit a .env file with real credentials.
# POSTGRES_PASSWORD must match the value used when the Docker volume was first created.
POSTGRES_PASSWORD=CHANGEME_STRONG_PASSWORD
DATABASE_URL=postgres://walkability:CHANGEME_STRONG_PASSWORD@localhost:5432/walkability
UPLOADS_DIR=./uploads
PORT=3001
CORS_ORIGIN=http://localhost:3000
