# P0-1: Replace CHANGEME_STRONG_PASSWORD with a real secret before running.
# Never commit a .env file with real credentials.
# POSTGRES_PASSWORD must match the value used when the Docker volume was first created.
POSTGRES_PASSWORD=CHANGEME_STRONG_PASSWORD
DATABASE_URL=postgres://walkability:CHANGEME_STRONG_PASSWORD@localhost:5432/walkability
UPLOADS_DIR=./uploads
PORT=3001
CORS_ORIGIN=http://localhost:3000
PUBLIC_URL=http://localhost

# Admin dashboard — JWT auth
JWT_SECRET=changeme-generate-with-openssl-rand-hex-64
JWT_SESSION_HOURS=24
COOKIE_SECURE=false          # set to true in production (HTTPS required)

# Admin seeding (idempotent — no-op if admin_users table already has rows)
# Safe to remove ADMIN_SEED_PASSWORD from env after first boot
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=changeme-use-a-strong-password
